[Unit]
Description=Spear fleet-link zone mesh protector
After=network-online.target spear-wartime.service
Wants=network-online.target
ConditionPathExists=/usr/local/bin/spear-fleet-link

[Service]
Type=simple
ExecStart=/usr/local/bin/spear-fleet-link
Restart=always
RestartSec=2
Nice=-5

[Install]
WantedBy=multi-user.target
