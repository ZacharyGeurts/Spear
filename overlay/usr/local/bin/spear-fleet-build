ROLES = [
    ("field-node", "FIE", "Field Node"),
    ("school", "SCH", "School"),
    ("library", "LIB", "Library"),
    ("municipal", "MUN", "Municipal"),
    ("clinic", "CLI", "Clinic"),
    ("fire", "FIR", "Fire"),
    ("sheriff", "SHE", "Sheriff"),
    ("water-plant", "WAT", "Water Plant"),
    ("tower", "TOW", "Tower"),
    ("co-op", "COO", "Co-op"),
    ("campus", "CAM", "Campus"),
    ("museum", "MUS", "Museum"),
    ("harbor", "HAR", "Harbor"),
    ("airport", "AIR", "Airport"),
    ("ranger", "RAN", "Ranger"),
    ("ems", "EMS", "EMS"),
    ("court", "COU", "Court"),
    ("post", "POS", "Post"),
    ("fiber-hut", "FIB", "Fiber Hut"),
    ("substation", "SUB", "Substation"),
]


def now_z() -> str:
    return time.strftime("%Y-%m-%dT%H:%MZ", time.gmtime())


def jitter_for(code: str) -> float:
    tiny = {"VA", "MC", "SM", "LI", "AD", "MT", "SG", "HK", "MO", "DC", "NR", "TV", "BH"}
    if code in tiny:
        return 0.08
    if code in ("RU", "CA", "US", "CN", "BR", "AU"):
        return 8.0
    return 1.2


def compact_system(code: str, n: int, lat0: float, lon0: float, name: str, rng: random.Random) -> dict:
    role_slug, role_code, role_label = ROLES[(n - 1) % len(ROLES)]
    j = jitter_for(code)
    lat = round(lat0 + rng.uniform(-j, j), 5)
    lon = round(lon0 + rng.uniform(-j, j), 5)
    # clamp lat
    lat = max(-85.0, min(85.0, lat))
    if lon > 180:
        lon -= 360
    if lon < -180:
        lon += 360
    site = f"{name} Site {(n - 1) % 40 + 1}"
    return {
        "id": f"{code.lower()}{n:04d}",
        "name": f"{code}-{role_code}-{n:04d}",
        "label": f"{site} {role_label}",
        "town": site,
        "county": name,
        "role": role_slug,
        "lat": lat,
        "lon": lon,
        "ip": f"10.{(abs(hash(code)) % 200) + 20}.{(n // 250) + 1}.{(n % 250) + 1}",
    }


def build_region(code, name, kind, lat, lon, zone, racks):
    rng = random.Random(SEED + abs(hash(code)) % 10_000_000)
    systems = [compact_system(code, i, lat, lon, name, rng) for i in range(1, racks + 1)]
    shard = {
        "schema": "spear-fleet-region/v1",
        "code": code,
        "name": name,
        "kind": kind,
        "zone": zone,
        "racks": racks,
        "centroid": {"lat": lat, "lon": lon},
        "systems": systems,
    }
    summary = {
        "code": code,
        "name": name,
        "kind": kind,
        "zone": zone,
        "racks": racks,
        "lat": lat,
        "lon": lon,
        "online": racks,
        "ok": racks,
        "status": "ok",
    }
    return shard, summary


def write_tree(base: Path, index: dict, shards: dict, meta: dict) -> None:
    fleet = base / "fleet"
    rdir = fleet / "r"
    # wipe old shards that are no longer in index (optional keep for safety — replace all)
    if rdir.is_dir():
        for old in rdir.glob("*.json"):
            old.unlink(missing_ok=True)
    rdir.mkdir(parents=True, exist_ok=True)
    (fleet / "index.json").write_text(json.dumps(index, separators=(",", ":")) + "\n", encoding="utf-8")
    (fleet / "meta.json").write_text(json.dumps(meta, indent=2) + "\n", encoding="utf-8")
    for code, shard in shards.items():
        (rdir / f"{code}.json").write_text(
            json.dumps(shard, separators=(",", ":")) + "\n", encoding="utf-8"
        )
    status = {
        "schema": "spear-fleet-status/v5",
        "mode": "REAL",
        "sandbox": False,
        "updated": now_z(),
        "total": index["total_racks"],
        "regions": index["region_count"],
        "racks_per_region": RACKS_PER,
        "by_region": {
            s["code"]: {"online": s["online"], "ok": s["ok"], "status": s["status"]}
            for s in index["regions"]
        },
        "zones": index["zones"],
        "map": {
            "image": "assets/maps/world-equirectangular.jpg",
            "projection": "equirectangular",
            "sync": "lat/lon → percent on image",
        },
        "motto": f"World fleet · {RACKS_PER}/country · map-synced · lazy load",
    }
    (fleet / "status.json").write_text(json.dumps(status, separators=(",", ":")) + "\n", encoding="utf-8")


def main() -> None:
    t0 = time.time()
    # de-dupe codes (last wins)
    seen = {}
    for row in COUNTRIES:
        seen[row[0]] = row
    for row in CITY_FLEETS:
        seen[row[0]] = row
    for row in EXTRA_DIVERSITY:
        if 2 <= len(row[0]) <= 3:
            seen[row[0]] = row
    regions = list(seen.values())

    shards = {}
    summaries = []
    zones: dict[str, list[str]] = {}
    for code, name, kind, lat, lon, zone in regions:
        shard, summary = build_region(code, name, kind, lat, lon, zone, RACKS_PER)
        shards[code] = shard
        summaries.append(summary)
        zones.setdefault(zone, []).append(code)

    total = len(summaries) * RACKS_PER
    index = {
        "schema": "spear-fleet-index/v2",
        "updated": now_z(),
        "racks_per_region": RACKS_PER,
        "region_count": len(summaries),
        "total_racks": total,
        "scalable": True,
        "lazy": True,
        "world": True,
        "map": {
            "image": "/assets/maps/world-equirectangular.jpg",
            "projection": "equirectangular",
            "x": "(lon + 180) / 360",
            "y": "(90 - lat) / 180",
        },
        "regions": summaries,
        "zones": {z: {"regions": codes, "racks": len(codes) * RACKS_PER} for z, codes in zones.items()},
        "api": {
            "regions": "/api/regions",
            "systems": "/api/systems?region=CODE&limit=50&offset=0",
            "dossier": "/api/dossier?id=",
            "export_csv": "/api/dossiers/export.csv",
            "export_json": "/api/dossiers/export.json",
        },
        "note": f"{RACKS_PER} racks per country · map pins sync to centroids · never fetch all racks",
    }
    meta = {
        "schema": "spear-fleet-meta/v2",
        "doctrine": "world countries + city fleets · 1500 racks each · map-synced equirectangular · no thrash",
        "racks_per_region": RACKS_PER,
        "regions": len(summaries),
        "total_racks": total,
        "map_projection": "equirectangular",
        "updated": now_z(),
    }

    roots = list(ROOTS)
    if HOSTESS.parent.is_dir():
        try:
            HOSTESS.mkdir(parents=True, exist_ok=True)
            roots.append(HOSTESS)
        except Exception:
            pass

    for base in roots:
        try:
            base.mkdir(parents=True, exist_ok=True)
            write_tree(base, index, shards, meta)
            stub = {
                "schema": "up-swallows-fleet/v4-world-sharded",
                "title": f"World fleet · {total} racks · {RACKS_PER}/country",
                "mode": "REAL",
                "sandbox": False,
                "sharded": True,
                "world": True,
                "total": total,
                "racks_per_region": RACKS_PER,
                "region_count": len(summaries),
                "index": "fleet/index.json",
                "map": index["map"],
                "systems": [],
                "count": total,
                "online": total,
                "note": "Use /api/systems?region=XX — full map on up-swallows.html",
            }
            (base / "up-systems.json").write_text(json.dumps(stub, indent=2) + "\n", encoding="utf-8")
            print(f"wrote {base}/fleet regions={len(summaries)} racks={total}")
        except Exception as e:
            print(f"skip {base}: {e}")

    sample = ROOTS[0] / "fleet"
    if sample.is_dir():
        sizes = [p.stat().st_size for p in (sample / "r").glob("*.json")]
        total_b = sum(sizes) + (sample / "index.json").stat().st_size
        print(
            f"disk shards={len(sizes)} total_MB={total_b/1e6:.2f} "
            f"avg_KB={ (sum(sizes)/max(len(sizes),1))/1e3 :.1f} "
            f"index_KB={(sample/'index.json').stat().st_size/1e3:.1f} "
            f"build_s={time.time()-t0:.2f}"
        )


if __name__ == "__main__":
    main()
