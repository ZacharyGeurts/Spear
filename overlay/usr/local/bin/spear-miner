#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Field data miner for Big Grin / UP Swallows fleet — loopback :9489
# Restores the offline-kb miner surface (not third-party crypto mining).
set -euo pipefail
PORT="${SPEAR_MINER_PORT:-9489}"
BIND="${SPEAR_MINER_BIND:-127.0.0.1}"
STATE="${SPEAR_SWALLOW_STATE:-/var/lib/spear/swallows}"
[[ -d "$STATE" ]] || STATE="${HOME}/.local/share/spear/swallows"
mkdir -p "$STATE"
LOG="${STATE}/miner-access.log"

# tiny pure-bash HTTP using ncat/python
serve_python() {
  exec python3 - "$BIND" "$PORT" "$STATE" <<'PY'
import json, os, sys, time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

bind, port, state = sys.argv[1], int(sys.argv[2]), sys.argv[3]
start = time.time()

class H(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        try:
            with open(os.path.join(state, "miner-access.log"), "a") as f:
                f.write(time.strftime("%Y-%m-%dT%H:%MZ ", time.gmtime()) + (fmt % args) + "\n")
        except Exception:
            pass

    def _json(self, code, obj):
        b = json.dumps(obj, indent=2).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(b)))
        self.send_header("X-Spear-Miner", "big-grin-swallows")
        self.end_headers()
        self.wfile.write(b)

    def do_GET(self):
        swallows = os.path.join(state, "swallows.csv")
        n = 0
        if os.path.isfile(swallows):
            with open(swallows, encoding="utf-8", errors="ignore") as f:
                n = max(0, sum(1 for _ in f) - 1)
        if self.path in ("/", "/status", "/api/status"):
            self._json(200, {
                "schema": "spear-miner/v1",
                "fleet": "big-grin-swallows",
                "sister": "up-swallows",
                "bind": f"{bind}:{port}",
                "uptime_s": int(time.time() - start),
                "swallows_logged": n,
                "motto": "rocket speed · single miner · separate from Gladstone fleet",
                "cli": "spear-swallow scan|eat",
            })
            return
        if self.path.startswith("/api/swallows"):
            rows = []
            if os.path.isfile(swallows):
                with open(swallows, encoding="utf-8", errors="ignore") as f:
                    rows = f.read().splitlines()[-50:]
            self._json(200, {"rows": rows})
            return
        self._json(404, {"error": "not_found"})

ThreadingHTTPServer((bind, port), H).serve_forever()
PY
}

case "${1:-serve}" in
  serve)
    echo "spear-miner listening ${BIND}:${PORT} (loopback field data miner)"
    serve_python
    ;;
  status)
    curl -fsS "http://${BIND}:${PORT}/status" 2>/dev/null || echo "miner not running"
    ;;
  *)
    echo "usage: spear-miner serve|status"
    exit 2
    ;;
esac
