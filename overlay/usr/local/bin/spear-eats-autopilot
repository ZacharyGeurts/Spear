def cycle() -> None:
    targets = collect_wartime_ips()
    threats = collect_dogshit_threats()
    rekill_state = load_json(REKILL_STATE, {"ips": {}})
    eaten_threats = set(load_json(EATEN_THREATS, {"threats": []}).get("threats") or [])

    cycle_actions = []
    latest = None
    ips_hit = 0
    threats_hit = 0

    # WARTIME: rekill EVERY registry IP every cycle (not skip-if-eaten)
    for ip, meta in sorted(targets.items()):
        prev = int((rekill_state.get("ips") or {}).get(ip, {}).get("rekill_count") or meta.get("rekill_count") or 0)
        n = prev + 1
        ev = field_attack_ip(ip, meta, n)
        rekill_state.setdefault("ips", {})[ip] = {
            "rekill_count": n,
            "last_rekill_at": now_z(),
            "vector": meta.get("vector"),
            "severity": meta.get("severity"),
        }
        ips_hit += 1
        latest = ev
        cycle_actions.append({"type": "ip", "target": ip, "attack": ev["attack"], "rekill": n, "how": ev["how"]})
        # live mid-cycle status so panel updates as it swallows
        publish_status(
            {"ips_rekilled": ips_hit, "threats_marked": threats_hit, "actions": cycle_actions[-40:], "in_progress": True},
            {
                "wartime_ips": len(targets),
                "ips_rekilled_lifetime": sum(int(v.get("rekill_count") or 0) for v in (rekill_state.get("ips") or {}).values()),
                "dogshit_threats": len(threats),
                "threats_permanent": len(eaten_threats),
            },
            latest,
        )
        # small stagger so live feed is readable
        time.sleep(0.05)

    # Dogshit / terrorist threats — permanent mark (once, then reaffirm each cycle as REKILL stamp)
    for t in threats:
        tid = t["id"]
        is_new = tid not in eaten_threats
        eaten_threats.add(tid)
        attack = "FIELD_SWALLOW" if is_new else "FIELD_REKILL"
        ev = {
            "schema": "field-attack/v1",
            "attack": attack,
            "phase": "SWALLOW",
            "fleet": "wartime",
            "target_type": "threat",
            "target": t.get("label") or tid,
            "vector": "DOGSHIT" if "dogshit" in (t.get("tags") or []) else "TERRORIST",
            "severity": t.get("severity") or "critical",
            "reason": "wartime_permanent_list",
            "tags": t.get("tags") or [],
            "ts": now_z(),
        }
        emit_live(ev)
        log_csv("wartime", "threat", tid, f"{attack} tags={','.join(t.get('tags') or [])}")
        threats_hit += 1
        latest = ev
        cycle_actions.append({"type": "threat", "target": tid[:80], "attack": attack})
        if threats_hit % 15 == 0:
            publish_status(
                {"ips_rekilled": ips_hit, "threats_marked": threats_hit, "actions": cycle_actions[-40:], "in_progress": True},
                {
                    "wartime_ips": len(targets),
                    "ips_rekilled_lifetime": sum(int(v.get("rekill_count") or 0) for v in (rekill_state.get("ips") or {}).values()),
                    "dogshit_threats": len(threats),
                    "threats_permanent": len(eaten_threats),
                },
                latest,
            )

    # GLOBAL STAGE — DESTROY · KILL · REKILL every copilot class every cycle
    # Scope: wartime fleet surface (world planet + big-grin + threat ledger). Not third-party infra exploit.
    copilot_global = load_json(
        COPILOT_GLOBAL,
        {
            "schema": "copilot-global-rekill/v1",
            "stage": "GLOBAL",
            "status": "KILL_REKILL",
            "blessing": "God Bless",
            "targets": {},
            "lifetime_rekills": 0,
        },
    )
    copilot_global.setdefault("targets", {})
    copilot_hits = 0
    for t in GLOBAL_COPILOT_TARGETS:
        tid = t["id"]
        eaten_threats.add(tid)
        prev = int((copilot_global["targets"].get(tid) or {}).get("rekill_count") or 0)
        n = prev + 1
        attack = "FIELD_STRIKE" if n == 1 else "FIELD_REKILL"
        if n == 1:
            attack = "FIELD_SWALLOW"
        elif n % 3 == 0:
            attack = "FIELD_BURN"
        elif n % 2 == 0:
            attack = "FIELD_SEVER"
        else:
            attack = "FIELD_REKILL"
        copilot_global["targets"][tid] = {
            "id": tid,
            "label": t["label"],
            "vector": t["vector"],
            "scope": t["scope"],
            "rekill_count": n,
            "last_rekill_at": now_z(),
            "status": "DESTROYED",
            "stage": "GLOBAL",
            "rule": "every_kill_gets_rekill",
        }
        copilot_global["lifetime_rekills"] = int(copilot_global.get("lifetime_rekills") or 0) + 1
        ev = {
            "schema": "field-attack/v1",
            "attack": attack,
            "phase": "GLOBAL_REKILL",
            "fleet": "world-planet",
            "stage": "GLOBAL",
            "target_type": "copilot",
            "target": t["label"],
            "vector": t["vector"],
            "severity": "critical",
            "reason": "global_stage_destroy_kill_rekill",
            "rekill_count": n,
            "areas": 359,
            "racks": 2154000,
            "blessing": "God Bless",
            "tags": ["copilot", "global_stage", "wartime", "every_kill_gets_rekill", "no_demo"],
            "ts": now_z(),
        }
        emit_live(ev)
        log_csv("world-planet", "copilot", tid, f"{attack} GLOBAL rekill={n} God_Bless")
        copilot_hits += 1
        threats_hit += 1
        latest = ev
        cycle_actions.append(
            {"type": "copilot_global", "target": tid, "attack": attack, "rekill": n, "stage": "GLOBAL"}
        )
        # hard dispose pass (C++ if present) — process identity only
        hard = Path.home() / ".local/bin/spear-hard-dispose"
        if hard.is_file() and os.access(hard, os.X_OK):
            try:
                subprocess.run([str(hard)], capture_output=True, timeout=8)
            except Exception:
                pass

    copilot_global["updated"] = now_z()
    copilot_global["status"] = "KILL_REKILL"
    copilot_global["stage"] = "GLOBAL"
    copilot_global["blessing"] = "God Bless"
    copilot_global["last_cycle_targets"] = copilot_hits
    copilot_global["policy"] = (
        "DESTROY · KILL · REKILL on global wartime stage · "
        "every_kill_gets_rekill · multi-signal process · cloud null-route file · leave GPT-4"
    )
    copilot_global["planet"] = {"areas": 359, "racks": 2154000, "defending": 2154000}
    mirror("copilot-global-rekill.json", copilot_global)
    COPILOT_GLOBAL.write_text(json.dumps(copilot_global, indent=2), encoding="utf-8")

    rekill_state["updated"] = now_z()
    rekill_state["last_cycle_ips"] = ips_hit
    rekill_state["last_cycle_threats"] = threats_hit
    rekill_state["copilot_global_last"] = copilot_hits
    mirror("wartime-rekill-state.json", rekill_state)
    (EATEN_THREATS).write_text(json.dumps({"threats": sorted(eaten_threats), "updated": now_z()}, indent=2), encoding="utf-8")

    totals = {
        "wartime_ips": len(targets),
        "ips_rekilled_this_cycle": ips_hit,
        "ips_rekilled_lifetime": sum(int(v.get("rekill_count") or 0) for v in (rekill_state.get("ips") or {}).values()),
        "dogshit_threats": len(threats),
        "threats_marked_this_cycle": threats_hit,
        "threats_permanent": len(eaten_threats),
        "copilot_global_rekills_this_cycle": copilot_hits,
        "copilot_global_lifetime": int(copilot_global.get("lifetime_rekills") or 0),
        "live_events": sum(1 for _ in LIVE_JSONL.open()) if LIVE_JSONL.is_file() else 0,
    }
    publish_status(
        {
            "ips_rekilled": ips_hit,
            "threats_marked": threats_hit,
            "actions": cycle_actions[-50:],
            "in_progress": False,
        },
        totals,
        latest,
    )
    print(
        f"[WARTIME] rekill_ips={ips_hit} threats={threats_hit} "
        f"lifetime_ip_rekills={totals['ips_rekilled_lifetime']}",
        flush=True,
    )


def main() -> None:
    print(f"WARTIME kill/rekill autopilot interval={INTERVAL}s · every_kill_gets_rekill · live Field attacks", flush=True)
    if not LIVE_JSONL.is_file():
        LIVE_JSONL.write_text("", encoding="utf-8")
    while True:
        try:
            cycle()
        except Exception as e:
            print(f"[WARTIME] error {e}", flush=True)
            emit_live({"attack": "FIELD_ERROR", "target": str(e), "phase": "ERROR", "fleet": "wartime"})
        time.sleep(INTERVAL)


if __name__ == "__main__":
    main()
