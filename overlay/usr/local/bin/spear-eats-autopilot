IP_RE = re.compile(r"^(?:(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\.){3}(?:25[0-5]|2[0-4]\d|[01]?\d\d?)$")

# Field attack choreography labels (display + ledger)
FIELD_ATTACKS = (
    "FIELD_STRIKE",
    "FIELD_JAM",
    "FIELD_SEVER",
    "FIELD_BURN",
    "FIELD_SWALLOW",
    "FIELD_REKILL",
)


def now_z() -> str:
    return time.strftime("%Y-%m-%dT%H:%MZ", time.gmtime())


def load_json(p: Path, default):
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return default


def mirror(name: str, obj) -> None:
    raw = json.dumps(obj, indent=2)
    (STATE / name).write_text(raw, encoding="utf-8")
    if WWW.is_dir():
        try:
            (WWW / name).write_text(raw, encoding="utf-8")
        except Exception:
            pass


def sacred_ip(ip: str) -> bool:
    if not IP_RE.match(ip):
        return True
    if ip.startswith(("127.", "0.", "255.", "224.", "239.")):
        return True
    # private field nets — never auto-block
    if ip.startswith("10.") or ip.startswith("192.168."):
        return True
    if ip.startswith("172."):
        try:
            if 16 <= int(ip.split(".")[1]) <= 31:
                return True
        except Exception:
            pass
    return False



def load_geo(ip: str) -> dict:
    """Attach real GPS from ip-geo-cache (filled by dossier enrich)."""
    for base in (STATE, WWW):
        p = base / "ip-geo-cache.json"
        if not p.is_file():
            continue
        try:
            cache = json.loads(p.read_text(encoding="utf-8"))
            g = cache.get(ip) or {}
            if g.get("lat") is not None:
                return g
        except Exception:
            continue
    return {}


def emit_live(event: dict) -> None:
    """Push one Field attack to live stream for the panel."""
    event = {**event, "ts": event.get("ts") or now_z()}
    with LIVE_JSONL.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, ensure_ascii=False) + "\n")
    # keep rolling feed of last 80
    feed = load_json(LIVE_FEED, {"schema": "live-feed/v1", "events": []})
    events = feed.get("events") or []
    events.append(event)
    feed = {
        "schema": "live-feed/v1",
        "updated": now_z(),
        "mode": "WARTIME",
        "events": events[-80:],
        "latest": event,
    }
    mirror("live-feed.json", feed)


def log_csv(fleet: str, kind: str, target: str, detail: str) -> None:
    if not LOG.is_file():
        LOG.write_text("ts,fleet,pid,comm,exe,score,action,detail\n", encoding="utf-8")
    with LOG.open("a", encoding="utf-8") as f:
        f.write(f"{now_z()},{fleet},ip-or-threat,{kind},{target},100,wartime_rekill,{detail}\n")


def field_attack_ip(ip: str, meta: dict, rekill_n: int) -> dict:
    """Full wartime kill+rekill of a hostile IP — block + ledger + live Field attack."""
    attack = FIELD_ATTACKS[rekill_n % len(FIELD_ATTACKS)]
    how = []

    # 1) persistent block list
    blocked = set()
    if BLOCKED.is_file():
        blocked = {ln.strip() for ln in BLOCKED.read_text().splitlines() if ln.strip()}
    if ip not in blocked:
        with BLOCKED.open("a", encoding="utf-8") as f:
            f.write(ip + "\n")
        how.append("blocklist")

    # 2) ufw deny (root if available)
    for cmd in (
        ["ufw", "insert", "1", "deny", "from", ip, "to", "any"],
        ["sudo", "-n", "ufw", "insert", "1", "deny", "from", ip, "to", "any"],
        ["ufw", "deny", "from", ip, "to", "any"],
        ["sudo", "-n", "ufw", "deny", "from", ip, "to", "any"],
    ):
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        if r.returncode == 0:
            how.append("ufw")
            break

    # 3) iptables/ip6tables DROP (hard)
    for cmd in (
        ["sudo", "-n", "iptables", "-I", "INPUT", "1", "-s", ip, "-j", "DROP"],
        ["sudo", "-n", "iptables", "-I", "OUTPUT", "1", "-d", ip, "-j", "DROP"],
        ["sudo", "-n", "iptables", "-I", "FORWARD", "1", "-s", ip, "-j", "DROP"],
        ["sudo", "-n", "iptables", "-I", "FORWARD", "1", "-d", ip, "-j", "DROP"],
    ):
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=8)
        if r.returncode == 0:
            how.append("iptables_DROP")
            break

    # 4) conntrack purge if present
    subprocess.run(
        ["sudo", "-n", "conntrack", "-D", "-s", ip],
        capture_output=True, timeout=5,
    )
    subprocess.run(
        ["sudo", "-n", "conntrack", "-D", "-d", ip],
        capture_output=True, timeout=5,
    )

    detail = f"{attack} rekill={rekill_n} how={'+'.join(how) or 'ledger'} vec={meta.get('vector','')} reason={meta.get('reason','')}"
    log_csv("wartime", "ip", ip, detail)

    event = {
        "schema": "field-attack/v1",
        "attack": attack,
        "phase": "SWALLOW",
        "fleet": "wartime",
        "target_type": "ip",
        "target": ip,
        "vector": meta.get("vector") or "HOSTILE",
        "severity": meta.get("severity") or "critical",
        "reason": meta.get("reason") or "wartime_rekill",
        "rekill_count": rekill_n,
        "how": how,
        "geo": meta.get("geo") or load_geo(ip) or {},
        "lat": (meta.get("geo") or load_geo(ip) or {}).get("lat"),
        "lon": (meta.get("geo") or load_geo(ip) or {}).get("lon"),
        "location": ", ".join(
            x for x in [
                (meta.get("geo") or load_geo(ip) or {}).get("city"),
                (meta.get("geo") or load_geo(ip) or {}).get("region"),
                (meta.get("geo") or load_geo(ip) or {}).get("country"),
            ] if x
        ),
        "ts": now_z(),
    }
    emit_live(event)
    return event


def collect_wartime_ips() -> dict[str, dict]:
    """Merge all wartime IP threat sources. Key = IP."""
    out: dict[str, dict] = {}

    def add(ip: str, **meta):
        if not ip or sacred_ip(ip):
            return
        cur = out.get(ip, {"ip": ip, "rekill_count": 0, "sources": [], "tags": []})
        for k, v in meta.items():
            if k == "sources" and isinstance(v, list):
                cur["sources"] = sorted(set(cur.get("sources", []) + v))
            elif k == "tags" and isinstance(v, list):
                cur["tags"] = sorted(set(cur.get("tags", []) + v))
            elif k == "rekill_count":
                cur["rekill_count"] = max(int(cur.get("rekill_count") or 0), int(v or 0))
            elif v:
                cur[k] = v
        out[ip] = cur

    # Primary: kill-rekill registry (every_kill_gets_rekill)
    reg = load_json(NEXUS_STATE / "kill-rekill-registry.json", {})
    for ip, e in (reg.get("entries") or {}).items():
        add(ip, sources=["kill-rekill-registry"], tags=["wartime", "rekill", "terrorist"],
            vector=e.get("vector"), severity=e.get("severity") or "critical",
            reason=e.get("reason"), rekill_count=int(e.get("rekill_count") or 0),
            boot_rekill=bool(e.get("boot_rekill")), every_kill_rekill=True)

    # boot-rekill validated list
    boot = load_json(NEXUS_STATE / "boot-rekill.json", {})
    for ip in (boot.get("revalidate") or {}).get("validated_ips") or boot.get("validated_ips") or []:
        add(ip, sources=["boot-rekill"], tags=["wartime", "boot"], severity="critical",
            reason="boot_rekill_validated")

    # field-hostile.tsv
    fh = NEXUS_STATE / "field-hostile.tsv"
    if fh.is_file():
        for i, line in enumerate(fh.read_text(encoding="utf-8", errors="ignore").splitlines()):
            if i == 0 and line.lower().startswith("ts"):
                continue
            # format may be concatenated without tabs — try both
            parts = line.split("\t") if "\t" in line else []
            if len(parts) >= 2:
                ip = parts[1]
                add(ip, sources=["field-hostile"], tags=["wartime", "hostile"],
                    vector=parts[2] if len(parts) > 2 else "",
                    severity=parts[3] if len(parts) > 3 else "critical",
                    reason=parts[4] if len(parts) > 4 else "")
            else:
                m = re.search(r"(\d+\.\d+\.\d+\.\d+)", line)
                if m:
                    add(m.group(1), sources=["field-hostile"], tags=["wartime", "hostile"],
                        severity="critical", reason="field_hostile")

    # nexus-hostile on Hostess
    if HOSTESS_HOSTILE.is_file():
        for line in HOSTESS_HOSTILE.read_text(encoding="utf-8", errors="ignore").splitlines():
            try:
                o = json.loads(line)
            except Exception:
                continue
            add(o.get("ip") or "", sources=["nexus-hostile"], tags=["wartime", "hostile", "terrorist"],
                vector=o.get("vector"), severity=o.get("severity") or "critical",
                reason=o.get("reason"), geo=o.get("geo") or {})

    # auto-rekill log IPs
    al = load_json(NEXUS_STATE / "auto-rekill-log.json", {})
    for ip in (al.get("entries") or {}):
        add(ip, sources=["auto-rekill-log"], tags=["wartime", "rekill"], severity="critical",
            reason="auto_rekill_history")

    return out


