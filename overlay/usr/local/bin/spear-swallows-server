#!/usr/bin/env python3
"""Spear Swallows web + API — Big Grin + region-sharded US fleet. Loopback only.

Infinite-scale design: never load all racks into memory or the browser.
  fleet/index.json     — region summary only
  fleet/r/{CODE}.json  — 320 compact racks per region
  /api/systems?region= — paginated one region at a time
"""
from __future__ import annotations

import csv
import json
import os
import re
import subprocess
import threading
import time
from collections import OrderedDict
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

BIND = os.environ.get("SPEAR_SWALLOWS_BIND", "127.0.0.1")
PORT = int(os.environ.get("SPEAR_SWALLOWS_PORT", "9490"))
ROOT = Path(os.environ.get(
    "SPEAR_SWALLOWS_ROOT",
    "/tmp/spear-swallows-www",
))
STATE = Path(os.environ.get(
    "SPEAR_SWALLOW_STATE",
    Path.home() / ".local/share/spear/swallows",
))
STATE.mkdir(parents=True, exist_ok=True)
LOG = STATE / "swallows.csv"
QUAR = STATE / "quarantine"
QUAR.mkdir(parents=True, exist_ok=True)
START = time.time()

SACRED = {
    "systemd", "init", "kthreadd", "sshd", "dbus-daemon", "NetworkManager",
    "pipewire", "wireplumber", "firefox", "chrome", "chromium", "Xorg",
    "wayland", "lightdm", "gdm", "sddm", "gnome-shell", "cinnamon",
    "containerd", "dockerd", "systemd-journald", "systemd-logind",
    "systemd-resolved", "systemd-networkd", "systemd-udevd", "rsyslogd",
    "cron", "agetty", "login", "bash", "sudo", "su", "spear",
    "spear-swallow", "spear-swallows-server", "spear-miner", "qemu-system-x86_64",
    "grok", "grokz", "python3", "http.server",
}

MINER_PAT = re.compile(
    r"xmrig|minerd|cpuminer|kdevtmpfsi|kinsing|cryptonight|stratum\+tcp|"
    r"nicehash|monero|ethminer|nbminer|phoenixminer|hellminer|watchbog|dbused",
    re.I,
)
SHELL_PAT = re.compile(
    r"bash -i|&>/dev/tcp/|nc -e |ncat .* -e|python3? -c .*(socket|connect)|"
    r"perl -e .*socket|php -r .*fsockopen",
    re.I,
)


def _read(path: Path, default: str = "") -> str:
    try:
        return path.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return default


def is_sacred(pid: int) -> bool:
    if pid <= 2:
        return True
    comm = _read(Path(f"/proc/{pid}/comm")).strip()
    if comm in SACRED:
        return True
    try:
        exe = os.readlink(f"/proc/{pid}/exe")
    except Exception:
        exe = ""
    if any(x in exe for x in ("spear", "nexus", "hostess", "grok")):
        return True
    return False


def detect_hotdog_kit_signals(comm: str, exe: str, cmdline: str) -> tuple[bool, int]:
    """Resilient Hotdog-hallway kit detect.

    Terrorist text injection (docs, browsers, our own kill-page paths) must NOT
    alone classify a process as the kit. Require multi-signal process reality.
    """
    comm_l = (comm or "").lower()
    exe_l = (exe or "").lower()
    cmd_l = (cmdline or "").lower()

    # Never treat document/browser/editor as the kit from body text alone
    readerish = {
        "firefox", "chrome", "chromium", "brave", "code", "cursor", "vim", "nvim",
        "nano", "less", "more", "cat", "head", "tail", "grep", "rg", "bat",
        "grok", "grokz", "evince", "okular", "libreoffice", "soffice",
    }
    if comm_l in readerish or any(x in exe_l for x in ("/firefox", "/chrome", "/chromium", "/code")):
        # only if the executable *itself* is named like the kit
        if not re.search(r"hotdog|hallway", Path(exe_l).name if exe_l else ""):
            return False, 0

    # Our own stack talking about the kit is not the kit
    if any(x in exe_l or x in cmd_l for x in (
        "spear-swallows-server", "spear-eats-autopilot", "spear-swallow",
        "spear-fleet-link", "dogshit-hotdog-down-a-hallway.html", "terrorist-oust",
    )):
        return False, 0

    signals = 0
    # Strong: process identity
    if re.search(r"hotdog", comm_l):
        signals += 2
    if re.search(r"hallway", comm_l):
        signals += 2
    # Strong: binary path looks like kit, not a library path
    exe_base = Path(exe_l).name if exe_l else ""
    if re.search(r"hotdog|hallway|hot-dog", exe_base):
        signals += 3
    if exe_l.startswith(("/tmp/", "/var/tmp/", "/dev/shm/")) and re.search(r"hotdog|hallway", exe_l + cmd_l):
        signals += 2
    # Medium: argv0 / primary token
    tokens = [t for t in re.split(r"\s+", cmd_l) if t]
    if tokens and re.search(r"hotdog|hallway|hot-dog-down", tokens[0]):
        signals += 2
    # Weak: phrase in cmdline (injection-prone — alone never enough)
    if re.search(r"hotdog\s*down\s*a\s*hallway|hotdog.*hallway|hallway.*hotdog", cmd_l):
        signals += 1

    # Need ≥3 signals for kit classification (resilient)
    return signals >= 3, signals


def detect_zocr_copilot_signals(comm: str, exe: str, cmdline: str) -> tuple[bool, int]:
    """zocr_copilot is THREAT — EAT. Multi-signal only. Leave GPT-4/OpenAI/Grok alone."""
    comm_l = (comm or "").lower()
    exe_l = (exe or "").lower()
    cmd_l = (cmdline or "").lower()
    blob = f"{comm_l} {exe_l} {cmd_l}"

    # Our kill pages / product talking about it is not the process
    if re.search(
        r"spear-|hostess|dogshit-zocr|ironclad-zocr|dogshit-copilot|ironclad-copilot",
        blob,
    ):
        return False, 0

    signals = 0
    if re.search(r"zocr_copilot|zocr-copilot|zocrcopilot", blob):
        signals += 4
    if re.fullmatch(r"zocr_copilot|zocr-copilot", comm_l or ""):
        signals += 3
    exe_base = Path(exe_l).name if exe_l else ""
    if re.search(r"zocr_copilot|zocr-copilot", exe_base):
        signals += 3
    if re.search(r"zocr_copilot\.py|zocr_copilot\.pyc", blob):
        signals += 3
    return signals >= 3, signals


def detect_copilot_signals(comm: str, exe: str, cmdline: str) -> tuple[bool, int]:
    """GitHub/Microsoft Copilot + zocr_copilot threat. Leave GPT-4/OpenAI/ChatGPT/Grok alone."""
    # zocr_copilot first — former leave-alone REVOKED
    z_hit, z_sig = detect_zocr_copilot_signals(comm, exe, cmdline)
    if z_hit:
        return True, z_sig

    comm_l = (comm or "").lower()
    exe_l = (exe or "").lower()
    cmd_l = (cmdline or "").lower()
    blob = f"{comm_l} {exe_l} {cmd_l}"

    # Never touch product / leave-alone stacks (zocr_copilot is NOT leave-alone)
    if re.search(
        r"spear-|hostess|dogshit-copilot|ironclad-copilot|dogshit-zocr|ironclad-zocr|grok|chatgpt|\bgpt-?4\b|openai",
        blob,
    ):
        # still allow if clearly github.copilot vendor agent
        if not re.search(r"github\.copilot|copilot-language-server|copilot-agent|microsoft.?copilot|copilot\.exe", blob):
            return False, 0

    signals = 0
    if re.search(r"github\.copilot", blob):
        signals += 3
    if re.search(r"copilot-language-server|copilot-agent", blob):
        signals += 3
    if re.search(r"microsoft.?copilot|copilot\.exe", blob):
        signals += 3
    if re.fullmatch(r"copilot", comm_l or ""):
        signals += 2
    exe_base = Path(exe_l).name if exe_l else ""
    if re.search(r"^(copilot|github\.copilot)", exe_base):
        signals += 3
    # bare substring "copilot" alone is insufficient (docs / browsers)
    return signals >= 3, signals




def score_pid(pid: int) -> tuple[int, str, str, str]:
    comm = _read(Path(f"/proc/{pid}/comm")).strip() or "?"
    try:
        exe = os.readlink(f"/proc/{pid}/exe")
    except Exception:
        exe = ""
    cmdline = _read(Path(f"/proc/{pid}/cmdline")).replace("\0", " ")
    blob = f"{comm} {cmdline} {exe}"
    score = 0
    if MINER_PAT.search(blob):
        score += 55
    if SHELL_PAT.search(blob):
        score += 45
    # Hotdog kit — multi-signal only (text injection alone does NOT score kit-level)
    kit_hit, kit_signals = detect_hotdog_kit_signals(comm, exe, cmdline)
    cop_hit, cop_signals = detect_copilot_signals(comm, exe, cmdline)
    if kit_hit:
        score += 90
    elif kit_signals >= 1:
        score += 10  # weak signal only — never sole OUST trigger
    cop_hit, cop_signals = detect_copilot_signals(comm, exe, cmdline)
    if cop_hit:
        score += 90
    elif cop_signals >= 1:
        score += 10
    if exe.startswith(("/tmp/", "/var/tmp/", "/dev/shm/")):
        score += 25
    if "/." in exe:
        score += 15
    if "(deleted)" in exe:
        score += 30
    try:
        # rough cpu from stat
        parts = _read(Path(f"/proc/{pid}/stat")).split()
        # not accurate percent; skip heavy calc
    except Exception:
        pass
    return min(score, 100), comm, exe, cmdline.strip()


def personal_from_pid(pid: int) -> dict:
    """Personal attribution for PID boards — user/uid/home/cwd/parent/cmdline when host sees them."""
    import pwd
    import grp

    score, comm, exe, cmdline = score_pid(pid)
    status = {}
    for line in _read(Path(f"/proc/{pid}/status")).splitlines():
        if ":" in line:
            k, v = line.split(":", 1)
            status[k.strip()] = v.strip()
    uid = gid = None
    try:
        uids = (status.get("Uid") or "").split()
        gids = (status.get("Gid") or "").split()
        uid = int(uids[0]) if uids else None
        gid = int(gids[0]) if gids else None
    except Exception:
        pass
    user = home = group = ""
    try:
        if uid is not None:
            pw = pwd.getpwuid(uid)
            user = pw.pw_name
            home = pw.pw_dir
    except Exception:
        pass
    try:
        if gid is not None:
            group = grp.getgrgid(gid).gr_name
    except Exception:
        pass
    try:
        cwd = os.readlink(f"/proc/{pid}/cwd")
    except Exception:
        cwd = ""
    try:
        ppid = int((status.get("PPid") or "0").split()[0])
    except Exception:
        ppid = 0
    parent_comm = _read(Path(f"/proc/{ppid}/comm")).strip() if ppid else ""
    # start time rough
    start_s = None
    try:
        start_s = int(Path(f"/proc/{pid}").stat().st_ctime)
    except Exception:
        pass
    environ_user = environ_home = ""
    try:
        env = _read(Path(f"/proc/{pid}/environ")).split("\0")
        for e in env:
            if e.startswith("USER="):
                environ_user = e.split("=", 1)[1]
            elif e.startswith("HOME="):
                environ_home = e.split("=", 1)[1]
    except Exception:
        pass
    personal = {
        "user": user or environ_user or "?",
        "uid": uid,
        "gid": gid,
        "group": group,
        "home": home or environ_home or "",
        "cwd": cwd,
        "tty": status.get("Tty") or status.get("tty_nr") or "",
        "ppid": ppid,
        "parent_comm": parent_comm,
        "cmdline": (cmdline or "")[:500],
        "exe": exe,
        "comm": comm,
        "start_s": start_s,
        "environ_user": environ_user,
        "environ_home": environ_home,
    }
    # Hotdog kit flag — resilient multi-signal (not text-injection theater)
    kit = None
    kit_hit, kit_signals = detect_hotdog_kit_signals(comm, exe, cmdline)
    cop_hit, cop_signals = detect_copilot_signals(comm, exe, cmdline)
    if kit_hit:
        kit = {
            "id": "hotdog-down-a-hallway",
            "label": "Hotdog down a Hallway",
            "kind": "terrorist_hacker_kit",
            "status": "OUST_TARGET",
            "vector": "HOTDOG_HALLWAY",
            "signals": kit_signals,
            "policy": "vector_to_source · clean_through · clean_out · every_kill_gets_rekill",
            "resilience": "multi_signal_not_text_injection",
        }
    elif cop_hit:
        z_hit, z_sig = detect_zocr_copilot_signals(comm, exe, cmdline)
        if z_hit:
            kit = {
                "id": "zocr-copilot",
                "label": "zocr_copilot",
                "kind": "non_ironclad_assistant",
                "status": "EAT_TARGET",
                "vector": "ZOCR_COPILOT",
                "signals": z_sig,
                "hostess7_mesh": False,
                "ironclad": "ironclad:zocr-copilot-eat:1",
                "policy": "EAT_ZOCR_COPILOT · SIGKILL_ONLY · no_fork · no_sleep · no_SIGTERM · C++/lower",
                "resilience": "multi_signal_not_text_injection",
                "pwnership_kill": "dogshit-zocr-copilot",
            }
        else:
            kit = {
                "id": "copilot-ironclad-fail",
                "label": "Copilot",
                "kind": "non_ironclad_assistant",
                "status": "DESTROY_TARGET",
                "vector": "COPILOT_FOREIGN",
                "signals": cop_signals,
                "hostess7_mesh": False,
                "ironclad": "ironclad:copilot-destroy:1",
                "policy": "DESTROY_COPILOT · SIGKILL_ONLY · vector_to_source · clean_through · clean_out",
                "resilience": "multi_signal_not_text_injection",
            }
    return {
        "schema": "spear-pid-dossier/v1",
        "pid": pid,
        "score": score,
        "comm": comm,
        "exe": exe,
        "cmdline": (cmdline or "")[:500],
        "personal": personal,
        "threat": False if not kit else True,
        "kit": kit,
        "vector_to_source": True,
        "clean_through": True,
        "clean_out": True,
        "summary": (
            f"PID DOSSIER {pid}\n"
            f"comm={comm} score={score}\n"
            f"user={personal['user']} uid={uid} gid={gid} home={personal['home']}\n"
            f"cwd={cwd}\n"
            f"ppid={ppid} parent={parent_comm}\n"
            f"exe={exe}\n"
            f"cmdline={cmdline[:200]}\n"
            + (f"KIT={kit['label']} STATUS=OUST\n" if kit else "")
            + "policy: vector to source · clean through · clean out\n"
        ),
    }


def scan(threshold: int = 40) -> list[dict]:
    out = []
    for name in os.listdir("/proc"):
        if not name.isdigit():
            continue
        pid = int(name)
        if is_sacred(pid):
            continue
        if not Path(f"/proc/{pid}/cmdline").is_file():
            continue
        score, comm, exe, cmdline = score_pid(pid)
        if score < threshold:
            continue
        person = personal_from_pid(pid)
        out.append({
            "pid": pid,
            "score": score,
            "comm": comm,
            "exe": exe,
            "cmdline": cmdline[:200],
            "personal": person.get("personal") or {},
            "threat": person.get("threat"),
            "kit": person.get("kit"),
            "summary": person.get("summary"),
        })
    out.sort(key=lambda x: -x["score"])
    return out


def log_row(fleet: str, pid: int, comm: str, exe: str, score: int, action: str, detail: str) -> None:
    if not LOG.is_file():
        LOG.write_text("ts,fleet,pid,comm,exe,score,action,detail\n", encoding="utf-8")
    with LOG.open("a", encoding="utf-8") as f:
        f.write(
            f"{time.strftime('%Y-%m-%dT%H:%MZ', time.gmtime())},{fleet},{pid},{comm},"
            f"{exe},{score},{action},{detail}\n"
        )


def eat(pid: int, force: bool = False, fleet: str = "big-grin") -> dict:
    if is_sacred(pid):
        return {"ok": False, "error": "sacred", "pid": pid}
    score, comm, exe, _ = score_pid(pid)
    if score < 40 and not force:
        log_row(fleet, pid, comm, exe, score, "skip", "below_threshold")
        return {"ok": False, "error": "below_threshold", "score": score, "pid": pid}

    # freeze cgroup v2
    cdir = Path("/sys/fs/cgroup/spear_swallow")
    try:
        cdir.mkdir(parents=True, exist_ok=True)
        freeze = cdir / "cgroup.freeze"
        procs = cdir / "cgroup.procs"
        if freeze.is_file() and procs.is_file():
            procs.write_text(str(pid), encoding="utf-8")
            freeze.write_text("1", encoding="utf-8")
    except Exception:
        pass

    # quarantine non-system binary
    quarantined = ""
    if exe and Path(exe).is_file() and not any(
        exe.startswith(p) for p in ("/usr/bin/", "/bin/", "/usr/lib/", "/usr/sbin/", "/sbin/")
    ):
        dest = QUAR / f"{int(time.time())}-{pid}-{Path(exe).name}"
        try:
            data = Path(exe).read_bytes()
            dest.write_bytes(data)
            dest.chmod(0o000)
            quarantined = str(dest)
            try:
                Path(exe).write_bytes(b"")
                Path(exe).unlink(missing_ok=True)
            except Exception:
                pass
        except Exception:
            pass

    # hard dispose remains — product rule: no TERM soft sequence
    try:
        os.kill(pid, 9)
    except ProcessLookupError:
        pass
    except PermissionError:
        # try via spear-swallow if setuid later
        subprocess.run(
            ["sudo", "-n", "/usr/local/bin/spear-swallow", "eat", str(pid), "--force"],
            capture_output=True,
            timeout=10,
        )

    person = personal_from_pid(pid)
    # mark clean_through on swallow
    detail = (
        f"freeze+quarantine+hard q={quarantined} "
        f"user={((person.get('personal') or {}).get('user'))} "
        f"vector_to_source clean_through clean_out"
    )
    if person.get("kit"):
        detail += f" kit={person['kit'].get('id')} OUST"
    log_row(fleet, pid, comm, exe, score, "swallowed", detail)
    return {
        "ok": True,
        "pid": pid,
        "comm": comm,
        "score": score,
        "quarantined": quarantined,
        "action": "swallowed",
        "fleet": fleet,
        "personal": person.get("personal"),
        "kit": person.get("kit"),
        "vector_to_source": True,
        "clean_through": True,
        "clean_out": True,
        "summary": person.get("summary"),
    }


# --- region-sharded fleet (LRU ≤4 shards — does not thrash RAM) ---
_FLEET_LOCK = threading.RLock()
_SHARD_LRU: OrderedDict[str, dict] = OrderedDict()
_SHARD_MAX = int(os.environ.get("SPEAR_FLEET_SHARD_CACHE", "4"))
_INDEX_CACHE: dict | None = None
_INDEX_MTIME = 0.0


def _fleet_dir() -> Path:
    return ROOT / "fleet"


def load_fleet_index() -> dict:
    """Tiny region summary — always safe to load."""
    global _INDEX_CACHE, _INDEX_MTIME
    p = _fleet_dir() / "index.json"
    if not p.is_file():
        # legacy monolith fallback
        leg = ROOT / "up-systems.json"
        if leg.is_file():
            try:
                d = json.loads(leg.read_text(encoding="utf-8"))
                if d.get("sharded"):
                    return {
                        "schema": "spear-fleet-index/v1",
                        "region_count": d.get("region_count") or 0,
                        "total_racks": d.get("total") or d.get("count") or 0,
                        "regions": [],
                        "sharded": True,
                    }
                systems = d.get("systems") or []
                return {
                    "schema": "spear-fleet-index/legacy",
                    "region_count": 1,
                    "total_racks": len(systems),
                    "regions": [{
                        "code": "LEG", "name": "Legacy", "racks": len(systems),
                        "online": sum(1 for s in systems if s.get("online", True)),
                        "ok": sum(1 for s in systems if s.get("status") == "ok"),
                        "status": "ok", "lat": 45.0, "lon": -87.0, "zone": "MW",
                    }],
                    "legacy_systems": systems,
                }
            except Exception:
                pass
        return {"schema": "spear-fleet-index/v1", "regions": [], "total_racks": 0, "region_count": 0}
    try:
        mtime = p.stat().st_mtime
    except Exception:
        mtime = 0.0
    if _INDEX_CACHE is not None and mtime == _INDEX_MTIME:
        return _INDEX_CACHE
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return {"regions": [], "total_racks": 0, "region_count": 0}
    # overlay live status (tiny file)
    st_path = _fleet_dir() / "status.json"
    if st_path.is_file():
        try:
            st = json.loads(st_path.read_text(encoding="utf-8"))
            by = st.get("by_region") or {}
            for r in data.get("regions") or []:
                code = r.get("code")
                if code in by:
                    r.update({k: by[code][k] for k in ("online", "ok", "status", "warn", "bad", "off") if k in by[code]})
        except Exception:
            pass
    _INDEX_CACHE = data
    _INDEX_MTIME = mtime
    return data


def load_region_shard(code: str) -> dict:
    """Load one region's racks. LRU-capped — never keeps whole nation in RAM."""
    code = (code or "").upper().strip()
    if not code:
        return {"systems": [], "code": code, "racks": 0}
    with _FLEET_LOCK:
        if code in _SHARD_LRU:
            _SHARD_LRU.move_to_end(code)
            return _SHARD_LRU[code]
    # legacy path
    idx = load_fleet_index()
    if idx.get("legacy_systems") is not None and code == "LEG":
        shard = {"code": "LEG", "systems": idx["legacy_systems"], "racks": len(idx["legacy_systems"])}
        return shard
    p = _fleet_dir() / "r" / f"{code}.json"
    if not p.is_file():
        return {"code": code, "systems": [], "racks": 0, "error": "region_not_found"}
    try:
        shard = json.loads(p.read_text(encoding="utf-8"))
    except Exception as e:
        return {"code": code, "systems": [], "racks": 0, "error": str(e)}
    # overlay region status onto compact systems (no stored fat status)
    st_path = _fleet_dir() / "status.json"
    reg_st = "ok"
    if st_path.is_file():
        try:
            st = json.loads(st_path.read_text(encoding="utf-8"))
            reg_st = ((st.get("by_region") or {}).get(code) or {}).get("status") or "ok"
        except Exception:
            pass
    for s in shard.get("systems") or []:
        if "status" not in s:
            s["status"] = reg_st
        if "online" not in s:
            s["online"] = reg_st in ("ok", "warn", "scan")
        s.setdefault("region", code)
        s.setdefault("state", code if len(code) == 2 else code)
    with _FLEET_LOCK:
        _SHARD_LRU[code] = shard
        _SHARD_LRU.move_to_end(code)
        while len(_SHARD_LRU) > _SHARD_MAX:
            _SHARD_LRU.popitem(last=False)
    return shard


# Capitals / principal cities for accurate naming where known
_CAPITALS = {
    "US": ("Washington", "DC", "United States"), "GB": ("London", "England", "United Kingdom"),
    "CA": ("Ottawa", "Ontario", "Canada"), "MX": ("Mexico City", "CDMX", "Mexico"),
    "BR": ("Brasília", "DF", "Brazil"), "AR": ("Buenos Aires", "CABA", "Argentina"),
